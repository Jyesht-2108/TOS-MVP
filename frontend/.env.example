# API Configuration
VITE_API_URL=http://localhost:8080/api/v1

# Development Mode
# Set to 'true' to use mock data instead of real backend API
# Useful for frontend development when backend is not available
VITE_USE_MOCK=true

# Mock API Mode
# Set to 'true' to intercept API calls and return mock data
# This allows testing the full application flow with sample data
VITE_USE_MOCK_API=true
